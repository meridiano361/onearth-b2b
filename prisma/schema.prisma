generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Collection {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  season    String
  year      Int
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  categories Category[]
  products   Product[]
  orders     Order[]

  @@map("collections")
}

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String
  parentId     String?
  order        Int        @default(0)
  collectionId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  collection Collection? @relation(fields: [collectionId], references: [id])
  products   Product[]

  @@unique([slug, collectionId])
  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  costPrice     Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  lotSize       Int      @default(1)
  imageUrl      String?
  imageUrl2     String?
  imageUrl3     String?
  imageUrl4     String?
  notes         String?
  categoryId    String?
  collectionId  String?
  isActive      Boolean  @default(true)
  stock         Int?
  famiglia           String?
  sottofamiglia      String?
  colore             String?
  nomLinea           String?
  misura             String?
  produttore         String?
  gruppoMerceologico String?
  classe             String?
  classe2            String?
  sottoclasse        String?
  sottoclasse2       String?
  gruppoOmogeneo     String?
  gruppoOmogeneo2    String?
  stagione           String?
  temaColore         String?
  temaColore2        String?
  temaColore3        String?
  temaColore4        String?
  temaColore5        String?
  modello            String?
  taglia             String?
  bloccoColore       String?
  costoIeConReso     Decimal? @db.Decimal(10, 2)
  costoIeSenzaReso   Decimal? @db.Decimal(10, 2)
  fasciaRicarico     String?
  fasciaSconto       Decimal? @db.Decimal(5, 2)
  collezione         String?
  tranche            String?
  paese              String?
  iva                Int      @default(22)
  conferente         String?
  materiale1         String?
  materiale2         String?
  materiale3         String?
  composizione       String?
  certificazione1    String?
  certificazione2    String?
  certificazione3    String?
  fantasia           String?
  lavorazione        String?
  dettaglio          String?
  descrizioneEn      String?
  descrizioneDe      String?
  descrizioneFr      String?
  descrizioneEs      String?
  createdAt          DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category?   @relation(fields: [categoryId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])
  orderItems   OrderItem[]
  favorites    Favorite[]
  cartItems    CartItem[]
  lookProdotti LookProdotto[]
  outfitItems  OutfitItem[]

  @@map("products")
}

model GruppoMerceologico {
  id        String     @id @default(cuid())
  nome      String     @unique
  createdAt DateTime   @default(now())
  famiglie  Famiglia[]
  @@map("cls_gruppi_merceologici")
}

model Famiglia {
  id                   String             @id @default(cuid())
  nome                 String
  gruppoMerceologicoId String
  createdAt            DateTime           @default(now())
  gruppoMerceologico   GruppoMerceologico @relation(fields: [gruppoMerceologicoId], references: [id], onDelete: Cascade)
  classi               Classe[]
  @@unique([nome, gruppoMerceologicoId])
  @@map("cls_famiglie")
}

model Classe {
  id          String        @id @default(cuid())
  nome        String
  famigliaId  String
  createdAt   DateTime      @default(now())
  famiglia    Famiglia      @relation(fields: [famigliaId], references: [id], onDelete: Cascade)
  sottoclassi Sottoclasse[]
  @@unique([nome, famigliaId])
  @@map("cls_classi")
}

model Sottoclasse {
  id             String           @id @default(cuid())
  nome           String
  classeId       String
  createdAt      DateTime         @default(now())
  classe         Classe           @relation(fields: [classeId], references: [id], onDelete: Cascade)
  gruppiOmogenei GruppoOmogeneo[]
  @@unique([nome, classeId])
  @@map("cls_sottoclassi")
}

model GruppoOmogeneo {
  id            String      @id @default(cuid())
  nome          String
  sottoclasseId String
  createdAt     DateTime    @default(now())
  sottoclasse   Sottoclasse @relation(fields: [sottoclasseId], references: [id], onDelete: Cascade)
  @@unique([nome, sottoclasseId])
  @@map("cls_gruppi_omogenei")
}

model Linea {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_linee")
}

model Stagione {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_stagioni")
}

model Collezione {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_collezioni")
}

model Colore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_colori")
}

model TemaColore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_temi_colore")
}

model Modello {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_modelli")
}

model BloccoColore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_blocchi_colore")
}

model Produttore {
  id        String   @id @default(cuid())
  nome      String   @unique
  paese     String?
  createdAt DateTime @default(now())
  @@map("lkp_produttori")
}

model Misura {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_misure")
}

model FasciaRicarico {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_fasce_ricarico")
}

model Tranche {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_tranche")
}

model AccessRequest {
  id               String   @id @default(cuid())
  organizzazione   String
  puntoVendita     String?
  nomeResponsabile String?
  nome             String?
  cognome          String?
  telefono         String?
  email            String
  status                  String    @default("pending")
  mailCredenzialiInviata  Boolean   @default(false)
  approvataDa             String?
  approvataAt             DateTime?
  createdAt               DateTime  @default(now())
  @@map("access_requests")
}

// ─── Admin staff (unchanged) ──────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  COMMERCIALE
  MAGAZZINO
  CUSTOMER
}

model Customer {
  id                   String   @id @default(cuid())
  companyName          String
  customerCode         String   @unique
  email                String   @unique
  passwordHash         String
  isActive             Boolean  @default(true)
  role                 Role     @default(CUSTOMER)
  phone                String?
  address              String?
  city                 String?
  country              String?
  vatNumber            String?
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  orders                 Order[]
  carts                  Cart[]
  customerNotifReads     CustomerNotificationRead[]
  surveyRecipients       SurveyRecipient[]
  surveyResponses        SurveyResponse[]

  @@map("customers")
}

// ─── Client hierarchy ─────────────────────────────────────────────────────────

enum CanaleTipo {
  BOTTEGA
  EMPORIO
  DISTRETTO
  STORE
  OUTLET
  TENDONE
  FIERA
  ONLINE
  ALTRO
}

model Organization {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())

  operatori Operator[]
  canali    Canale[]
  ordini    Order[]

  @@map("organizations")
}

model Operator {
  id                     String   @id @default(cuid())
  nome                   String
  cognome                String
  email                  String
  telefono               String?
  ruolo                  String?
  passwordHash           String
  organizationId         String
  attivo                 Boolean  @default(true)
  featureMondiEspositivi Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ordini          Order[]
  carts           Cart[]
  favorites       Favorite[]
  displayPresets  DisplayGroupPreset[]
  spaziEspositivi SpazioEspositivo[]

  @@map("operators")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

enum CartStatus {
  DRAFT
  CONVERTED
}

model Cart {
  id         String     @id @default(cuid())
  name       String
  status     CartStatus @default(DRAFT)
  customerId String?
  operatorId String?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  operator Operator? @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ─── Canale ───────────────────────────────────────────────────────────────────

model Canale {
  id             String     @id @default(cuid())
  nome           String
  tipo           CanaleTipo @default(BOTTEGA)
  citta          String?
  indirizzo      String?
  budget         Float?
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ordini       Order[]

  @@map("canali")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

enum OrderStatus {
  MERCE_DA_ORDINARE
  MERCE_ORDINATA
  MERCE_PARZIALMENTE_PRONTA
  MERCE_PRONTA_DA_AVVISARE
  MERCE_PRONTA_AVVISATO
  ESPORTATO
  ANNULLATO
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String?     @unique
  customerId     String?
  organizationId String?
  canaleId       String?
  operatorId     String?
  collectionId   String?
  status                OrderStatus @default(MERCE_DA_ORDINARE)
  totalValue            Decimal     @db.Decimal(10, 2) @default(0)
  totalItems            Int         @default(0)
  notes                 String?
  budgetPersonalizzato  Decimal?    @db.Decimal(10, 2)
  budgetNota            String?
  catalogBranch         String?     @default("casa27") // 'casa27' | 'modaPE27'
  createdAt             DateTime    @default(now())
  confirmedAt           DateTime?
  updatedAt             DateTime    @updatedAt

  customer       Customer?      @relation(fields: [customerId], references: [id])
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  canale         Canale?        @relation(fields: [canaleId], references: [id])
  operator       Operator?      @relation(fields: [operatorId], references: [id])
  collection     Collection?    @relation(fields: [collectionId], references: [id])
  items          OrderItem[]
  displayGroups  DisplayGroup[]

  @@map("orders")
}

model Favorite {
  id         String   @id @default(cuid())
  operatorId String
  productId  String
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([operatorId, productId])
  @@map("favorites")
}

model Document {
  id          String   @id @default(cuid())
  nome        String
  tipo        String
  descrizione String?
  url         String
  storageKey  String
  size        Int
  mimeType    String?
  visibile    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("documents")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  mercePronta Int     @default(0)
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product            @relation(fields: [productId], references: [id])
  displayGroups  DisplayGroupItem[]

  @@unique([orderId, productId])
  @@map("order_items")
}

// ─── Mondi Espositivi (Display Groups) ───────────────────────────────────────

model DisplayGroup {
  id           String   @id @default(cuid())
  orderId      String
  nome         String
  descrizione  String?
  coloreTag    String?
  stagione     String?
  temaTag      String?
  posizione    Int      @default(0)
  nomiLivelli  String?
  hasFocusCard Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order     Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  prodotti  DisplayGroupItem[]
  schedules DisplayGroupSchedule[]

  @@map("display_groups")
}

model DisplayGroupSchedule {
  id          String  @id @default(cuid())
  groupId     String
  spazioId    String?
  anno        Int
  settimanaIn Int
  settimanaFn Int
  nota        String?

  group  DisplayGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  spazio SpazioEspositivo? @relation(fields: [spazioId], references: [id], onDelete: SetNull)

  @@map("display_group_schedules")
}

model SpazioEspositivo {
  id         String   @id @default(cuid())
  operatorId String
  nome       String
  posizione  Int      @default(0)
  createdAt  DateTime @default(now())

  operator  Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  schedules DisplayGroupSchedule[]

  @@map("spazi_espositivi")
}

model DisplayGroupItem {
  id          String  @id @default(cuid())
  groupId     String
  orderItemId String
  nota        String?
  posizione   Int     @default(0)
  isFocus     Boolean @default(false)
  livello     Int     @default(1)

  group     DisplayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItem OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([groupId, orderItemId])
  @@map("display_group_items")
}

model DisplayGroupPreset {
  id          String   @id @default(cuid())
  operatorId  String
  nome        String
  descrizione String?
  coloreTag   String?
  temaTag     String?
  createdAt   DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@map("display_group_presets")
}

model CatalogTemplate {
  id            String   @id @default(cuid())
  nome          String
  configurazione Json
  createdAt     DateTime @default(now())

  @@map("catalog_templates")
}

model AppSettings {
  id        String   @id @default(cuid())
  chiave    String   @unique
  valore    String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model CatalogSettings {
  id             String   @id @default(cuid())
  filtriVisibili Json     @default("[]")
  updatedAt      DateTime @updatedAt

  @@map("catalog_settings")
}

model Notification {
  id                String             @id @default(cuid())
  titolo            String
  testo             String
  icona             String             @default("📢")
  tipo              String             @default("Informazione")
  coloreSfondo      String             @default("#000000")
  coloreTesto       String             @default("#FFFFFF")
  destinatari       String             @default("tutti")
  dataInizio        DateTime           @default(now())
  dataScadenza      DateTime?
  linkUrl           String?
  linkTesto         String?
  attiva            Boolean            @default(false)
  sentToCustomersAt DateTime?
  createdAt         DateTime           @default(now())
  reads             NotificationRead[]
  customerReads     CustomerNotificationRead[]

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userEmail String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model CustomerNotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  customerId     String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([notificationId, customerId])
  @@map("customer_notification_reads")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  operatorId     String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, operatorId])
  @@map("notification_reads")
}

model AccessLog {
  id          String   @id @default(cuid())
  operatorId  String
  loginAt     DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  dispositivo String?  // "mobile" | "tablet" | "desktop"

  @@map("access_logs")
}

model Album {
  id          String      @id @default(cuid())
  nome        String
  descrizione String?
  copertina   String?
  visibile    Boolean     @default(false)
  ordine      Int         @default(0)
  createdAt   DateTime    @default(now())
  foto        AlbumFoto[]

  @@map("albums")
}

model AlbumFoto {
  id         String   @id @default(cuid())
  albumId    String
  url        String
  didascalia String?
  ordine     Int      @default(0)
  createdAt  DateTime @default(now())
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("album_foto")
}

model OutfitEspositivo {
  id          String   @id @default(cuid())
  titolo      String
  descrizione String?
  collezione  String   @default("PE27")
  coloriGuida Json     @default("[]") // [{hex: string, label: string}]
  fantasia    String?                 // e.g. "Misto lino / cotone grezzo"
  imageUrl    String?
  isActive    Boolean  @default(true)
  ordine      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items OutfitItem[]

  @@map("outfit_espositivi")
}

model OutfitItem {
  id        String  @id @default(cuid())
  outfitId  String
  productId String
  zona      String  @default("centro") // 'centro' | 'destra'
  ordine    Int     @default(0)
  note      String?

  outfit  OutfitEspositivo @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([outfitId, productId])
  @@map("outfit_items")
}

// ─── Survey ───────────────────────────────────────────────────────────────────

model Survey {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  status      String   @default("draft") // draft | active | closed
  createdAt   DateTime @default(now())

  questions  SurveyQuestion[]
  recipients SurveyRecipient[]
  responses  SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id           String   @id @default(cuid())
  surveyId     String
  sortOrder    Int
  questionKey  String
  questionText String
  questionType String   // stars | multi_select | single_select | text
  optionsJson  Json?
  required     Boolean  @default(true)
  createdAt    DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, questionKey])
  @@map("survey_questions")
}

model SurveyRecipient {
  id              String    @id @default(cuid())
  surveyId        String
  customerId      String?
  email           String
  respondentName  String?   // companyName (customer) o nome+cognome (operator)
  token           String    @unique @default(cuid())
  pushSentAt      DateTime?
  emailSentAt     DateTime?
  openedAt        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  deliveryChannel String?   // push | email | both | none
  status          String    @default("pending") // pending | sent | opened | started | completed
  createdAt       DateTime  @default(now())

  survey   Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([surveyId, email])
  @@map("survey_recipients")
}

model SurveyResponse {
  id            String    @id @default(cuid())
  surveyId      String
  customerId    String?
  email         String
  respondentName String?
  submittedAt   DateTime  @default(now())
  sourceChannel String?   // push | email | in_app
  completed     Boolean   @default(false)
  createdAt     DateTime  @default(now())

  survey   Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  answers  SurveyAnswer[]

  @@unique([surveyId, email])
  @@map("survey_responses")
}

model SurveyAnswer {
  id           String   @id @default(cuid())
  responseId   String
  questionKey  String
  answerText   String?
  answerNumber Decimal? @db.Decimal(5, 2)
  answerJson   Json?
  createdAt    DateTime @default(now())

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@map("survey_answers")
}

model Look {
  id          String   @id @default(cuid())
  titolo      String
  descrizione String?
  imageUrl    String?
  collezione  String   @default("PE27")
  isActive    Boolean  @default(true)
  ordine      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prodotti LookProdotto[]

  @@map("looks")
}

model LookProdotto {
  id        String  @id @default(cuid())
  lookId    String
  productId String
  ordine    Int     @default(0)
  note      String?
  tipo      String  @default("look_item") // 'look_item' | 'completa_look' | 'accessorio' | 'gioiello'

  look    Look    @relation(fields: [lookId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([lookId, productId])
  @@map("look_prodotti")
}
