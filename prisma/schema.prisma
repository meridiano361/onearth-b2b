generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Collection {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  season    String
  year      Int
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  categories Category[]
  products   Product[]
  orders     Order[]

  @@map("collections")
}

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String
  parentId     String?
  order        Int        @default(0)
  collectionId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  collection Collection? @relation(fields: [collectionId], references: [id])
  products   Product[]

  @@unique([slug, collectionId])
  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  costPrice     Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  lotSize       Int      @default(1)
  imageUrl      String?
  notes         String?
  categoryId    String?
  collectionId  String?
  isActive      Boolean  @default(true)
  stock         Int?
  famiglia           String?
  sottofamiglia      String?
  colore             String?
  nomLinea           String?
  misura             String?
  produttore         String?
  gruppoMerceologico String?
  classe             String?
  sottoclasse        String?
  gruppoOmogeneo     String?
  stagione           String?
  temaColore         String?
  fasciaRicarico     String?
  collezione         String?
  tranche            String?
  iva                Int      @default(22)
  createdAt          DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category?   @relation(fields: [categoryId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model GruppoMerceologico {
  id        String     @id @default(cuid())
  nome      String     @unique
  createdAt DateTime   @default(now())
  famiglie  Famiglia[]
  @@map("cls_gruppi_merceologici")
}

model Famiglia {
  id                   String             @id @default(cuid())
  nome                 String
  gruppoMerceologicoId String
  createdAt            DateTime           @default(now())
  gruppoMerceologico   GruppoMerceologico @relation(fields: [gruppoMerceologicoId], references: [id], onDelete: Cascade)
  classi               Classe[]
  @@unique([nome, gruppoMerceologicoId])
  @@map("cls_famiglie")
}

model Classe {
  id          String        @id @default(cuid())
  nome        String
  famigliaId  String
  createdAt   DateTime      @default(now())
  famiglia    Famiglia      @relation(fields: [famigliaId], references: [id], onDelete: Cascade)
  sottoclassi Sottoclasse[]
  @@unique([nome, famigliaId])
  @@map("cls_classi")
}

model Sottoclasse {
  id             String           @id @default(cuid())
  nome           String
  classeId       String
  createdAt      DateTime         @default(now())
  classe         Classe           @relation(fields: [classeId], references: [id], onDelete: Cascade)
  gruppiOmogenei GruppoOmogeneo[]
  @@unique([nome, classeId])
  @@map("cls_sottoclassi")
}

model GruppoOmogeneo {
  id            String      @id @default(cuid())
  nome          String
  sottoclasseId String
  createdAt     DateTime    @default(now())
  sottoclasse   Sottoclasse @relation(fields: [sottoclasseId], references: [id], onDelete: Cascade)
  @@unique([nome, sottoclasseId])
  @@map("cls_gruppi_omogenei")
}

model Linea {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_linee")
}

model Stagione {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_stagioni")
}

model Collezione {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_collezioni")
}

model Colore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_colori")
}

model TemaColore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("cls_temi_colore")
}

model Produttore {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_produttori")
}

model Misura {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_misure")
}

model FasciaRicarico {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_fasce_ricarico")
}

model Tranche {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  @@map("lkp_tranche")
}

model AccessRequest {
  id               String   @id @default(cuid())
  organizzazione   String
  puntoVendita     String
  nomeResponsabile String
  email            String
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  @@map("access_requests")
}

// ─── Admin staff (unchanged) ──────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  COMMERCIALE
  MAGAZZINO
  CUSTOMER
}

model Customer {
  id            String   @id @default(cuid())
  companyName   String
  customerCode  String   @unique
  email         String   @unique
  passwordHash  String
  isActive      Boolean  @default(true)
  role          Role     @default(CUSTOMER)
  phone         String?
  address       String?
  city          String?
  country       String?
  vatNumber     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

// ─── Client hierarchy ─────────────────────────────────────────────────────────

enum CanaleTipo {
  BOTTEGA
  TENDONE
  ONLINE
  ALTRO
}

model Organization {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())

  operatori Operator[]
  canali    Canale[]
  ordini    Order[]

  @@map("organizations")
}

model Operator {
  id             String   @id @default(cuid())
  nome           String
  cognome        String
  email          String   @unique
  telefono       String?
  passwordHash   String
  organizationId String
  attivo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ordini       Order[]

  @@map("operators")
}

model Canale {
  id             String     @id @default(cuid())
  nome           String
  tipo           CanaleTipo @default(BOTTEGA)
  citta          String?
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ordini       Order[]

  @@map("canali")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

enum OrderStatus {
  MERCE_DA_ORDINARE
  MERCE_ORDINATA
  MERCE_PARZIALMENTE_PRONTA
  MERCE_PRONTA_DA_AVVISARE
  MERCE_PRONTA_AVVISATO
  ESPORTATO
  ANNULLATO
}

model Order {
  id             String      @id @default(cuid())
  customerId     String?
  organizationId String?
  canaleId       String?
  operatorId     String?
  collectionId   String?
  status         OrderStatus @default(MERCE_DA_ORDINARE)
  totalValue     Decimal     @db.Decimal(10, 2) @default(0)
  totalItems     Int         @default(0)
  notes          String?
  createdAt      DateTime    @default(now())
  confirmedAt    DateTime?
  updatedAt      DateTime    @updatedAt

  customer     Customer?     @relation(fields: [customerId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  canale       Canale?       @relation(fields: [canaleId], references: [id])
  operator     Operator?     @relation(fields: [operatorId], references: [id])
  collection   Collection?   @relation(fields: [collectionId], references: [id])
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  mercePronta Int     @default(0)
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@map("order_items")
}
